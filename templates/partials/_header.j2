    <header class="site-header">
        <div class="container header-inner">
            <a href="index.html" class="logo">
                <span class="logo-mark">◐</span>
                <span class="logo-text">The Digest</span>
            </a>
            <nav class="site-nav">
                <a href="ecommerce.html"{% if active == 'ecommerce' %} class="active"{% endif %} data-short="Ecomm">E-commerce</a>
                <a href="fintech.html"{% if active == 'fintech' %} class="active"{% endif %} data-short="Fintech">Fintech</a>
                <a href="ai.html"{% if active == 'ai' %} class="active"{% endif %} data-short="AI">AI</a>
            </nav>
            <div class="header-right">
                <div class="header-search">
                    <input type="search" id="header-search-input" placeholder="Search stories…" aria-label="Search stories">
                </div>
                <button class="search-toggle" type="button" aria-label="Search" aria-expanded="false">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                </button>
                <button class="theme-toggle" type="button" aria-label="Toggle dark mode">☾</button>
            </div>
            <div class="header-search-dropdown">
                <input type="search" id="mobile-search-input" placeholder="Search stories…" aria-label="Search stories">
            </div>
        </div>
    </header>

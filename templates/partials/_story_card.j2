                    <article class="story-card reveal" data-topic="{{ a.subtopic }}">
                        <span class="tag tag-alt">{{ subtopic_labels[a.subtopic] }}</span>
                        <h3><a href="{{ a.url }}" target="_blank" rel="noopener">{{ a.title }}</a></h3>
                        <p>{{ a.summary }}</p>
                        <div class="card-foot">
                            <span><a href="{{ a.url }}" target="_blank" rel="noopener">{{ a.source_name }}</a></span>
                            <span>{{ a.age_label }}</span>
                        </div>
                    </article>
